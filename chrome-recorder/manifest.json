{
  "manifest_version": 3,
  "name": "Chrome Video & Audio Recorder",
  "version": "1.0",
  "description": "Premium browser recorder that captures tab video and audio and saves locally.",
  "permissions": [
    "tabCapture",
    "activeTab",
    "offscreen",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Record Tab"
  }
}
